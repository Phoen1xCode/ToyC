// p12_const_expr_chain: 常量链式传播
int main() {
  int a = 1;
  int b = a + 1;       // 2
  int c = b + 1;       // 3
  int d = c + 1;       // 4
  int e = d + 1;       // 5
  int f = e + 1;       // 6
  int g = f + 1;       // 7
  int h = g + 1;       // 8
  int i0 = 0;
  int s = 0;
  while (i0 < 10000) {
    s = s + h;          // h constant 8
    i0 = i0 + 1;
  }
  return (s + a + b + c + d + e + f + g + h) % 256;
}