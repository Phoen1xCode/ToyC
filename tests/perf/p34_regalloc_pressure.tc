// p34_regalloc_pressure: 寄存器分配压力
// 循环体内 12 个同时活跃的命名变量 + s + i = 14 个,超出 s2..s11 的 10 个。
// 当前 top-N 频次分配会让 4 个变量走栈;线性扫描应能动态分配更多。
int main() {
  int s = 0;
  int i = 0;
  while (i < 8000) {
    int a1 = i + 1;
    int a2 = i + 2;
    int a3 = i + 3;
    int a4 = i + 4;
    int a5 = i + 5;
    int a6 = i + 6;
    int a7 = i + 7;
    int a8 = i + 8;
    int a9 = i + 9;
    int a10 = i + 10;
    int a11 = i + 11;
    int a12 = i + 12;
    s = s + a1 + a2 + a3 + a4 + a5 + a6 + a7 + a8 + a9 + a10 + a11 + a12;
    i = i + 1;
  }
  return s % 256;
}
