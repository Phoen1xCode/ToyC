// p19_gcd_pairs: 双层循环 + 迭代 GCD（取模为热点）
int gcd(int a, int b) {
  while (b != 0) {
    int t = a - (a / b) * b;  // a % b without using %
    a = b;
    b = t;
  }
  return a;
}
int main() {
  int s = 0;
  int i = 1;
  while (i <= 80) {
    int j = 1;
    while (j <= 80) {
      s = s + gcd(i, j);
      j = j + 1;
    }
    i = i + 1;
  }
  return s % 256;
}
