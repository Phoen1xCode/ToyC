// Nested loops with invariants in outer/inner
int main() {
  int s = 0;
  int i = 0;
  const int BASE = 7;
  while (i < 20) {
    int j = 0;
    int outer_inv = BASE + i;  // invariant in inner loop
    while (j < 30) {
      int inner_inv = BASE * 2;  // invariant in both
      s = s + outer_inv + inner_inv;
      j = j + 1;
    }
    i = i + 1;
  }
  return s % 256;
}
